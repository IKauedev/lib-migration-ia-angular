{
  "name": "ng-migrate-angularjs-ai",
  "version": "0.0.1",
  "description": "CLI inteligente para migração de AngularJS → Angular 21 usando IA (multi-provider)",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "ng-migrate": "./src/index.js"
  },
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "migrate": "node src/index.js migrate",
    "repl": "node src/index.js repl",
    "install-global": "npm install -g .",
    "uninstall-global": "npm uninstall -g ng-migrate-angularjs-ai",
    "prepublishOnly": "node -e \"console.log('Publicando ng-migrate-angularjs-ai...')\"",
    "postinstall": "node -e \"console.log('\\n  ng-migrate-angularjs-ai instalado! Execute: ng-migrate-angularjs-ai\\n')\""
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.77.0",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/google-genai": "^0.1.0",
    "zod": "^3.23.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^10.0.0",
    "boxen": "^7.1.1",
    "glob": "^11.0.0",
    "commander": "^12.0.0",
    "simple-git": "^3.27.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^6.1.0",
    "cli-progress": "^3.12.0",
    "diff": "^7.0.0",
    "js-yaml": "^4.1.0"
  },
  "keywords": [
    "angular",
    "angularjs",
    "migration",
    "cli",
    "ai",
    "openai",
    "azure",
    "gemini",
    "anthropic",
    "angular-migration",
    "angularjs-to-angular",
    "ng-migrate"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE.md",
    "install.ps1",
    "install.sh"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IKauedev/lib-migration-ia-angular.git"
  },
  "author": "ikauedev <ikauedeveloper@gmail.com>",
  "publishConfig": {
    "access": "public"
  }
}
